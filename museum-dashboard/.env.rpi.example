# Copy to .env.local and replace <RPI_IP>
# Example: 192.168.1.120

# For Vite dev proxy target
VITE_PROXY_TARGET=http://<RPI_IP>:5000

# For direct API calls (build/preview and optional explicit override)
VITE_API_URL=http://<RPI_IP>:5000/api

# For socket.io endpoint (build/preview and optional explicit override)
VITE_SOCKET_URL=http://<RPI_IP>:5000
